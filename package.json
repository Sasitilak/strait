    "ora": "^8.1.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "claude",
    "codex",
    "cli",
    "ai",
    "session",
    "translate"
