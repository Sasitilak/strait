{
  "name": "strait-cli",
  "version": "0.0.2",
  "description": "Move your AI agent sessions between Claude Code, Codex, and OpenCode",
  "type": "module",
  "bin": {
    "strait": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test:parser": "tsx scripts/test-parser.ts",
    "test:emitter": "tsx scripts/test-emitter.ts"
  },
  "files": ["dist/index.js", "dist/sql-wasm.wasm", "README.md", "LICENSE"],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/prompts": "^5.5.0",
    "chalk": "^5.3.0",
    "citty": "^0.1.6",
    "ora": "^8.1.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "opencode",
    "cli",
    "ai",
    "agent",
    "session",
    "translate",
    "portability"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sasitilak/strait.git"
  },
  "homepage": "https://github.com/Sasitilak/strait#readme",
  "bugs": {
    "url": "https://github.com/Sasitilak/strait/issues"
  }
}
