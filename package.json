{
  "name": "strait",
  "version": "0.0.1",
  "description": "Move your AI agent sessions between Claude Code and Codex",
  "type": "module",
  "bin": {
    "strait": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "test:parser": "tsx scripts/test-parser.ts",
    "test:emitter": "tsx scripts/test-emitter.ts"
  },
  "files": ["dist", "src", "tsup.config.ts", "tsconfig.json", "README.md", "LICENSE"],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/prompts": "^5.5.0",
    "chalk": "^5.3.0",
